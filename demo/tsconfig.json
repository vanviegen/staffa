{
  // Type-checks and compiles the demo against Staffa's *built* types, mirroring the
  // import map in index.html (which resolves "staffa" -> ../dist/index.js at
  // runtime). Run `npm run build` first so ../dist exists.
  //
  // Self-contained (rather than extending ../tsconfig.json) because the demo
  // compiles in place — demo.ts -> demo.js next to it — so it must not inherit the
  // library's rootDir/outDir.
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "staffa": ["../dist/index.d.ts"]
    }
  },
  "include": ["demo.ts"]
}
